<% content_for :title, "Scouting reports" %>

<div class="app-main">
  <aside class="sidebar" id="Sidebar" data-controller="report-search">
    <div class="sidebar-header">
      <h2>Scouting Reports</h2>

      <div class="sidebar-header-actions">
        <button class="sidebar-toggle" id="SidebarToggle" type="button">
          ≡
        </button>

        <%= link_to "+", new_scouting_report_path, class: "new-report-button", title: "New scouting report", data: { turbo_frame: "main_panel" } %>
      </div>
    </div>

    <div class="sidebar-search">
      <input
        id="reportSearch"
        class="sidebar-search-input"
        type="search"
        placeholder="Search player name"
        autocomplete="off"
        data-report-search-target="input"
        data-action="input->report-search#filter"
      >
    </div>

    <div class="reports-column-header">
      <div>Player Name</div>
      <div>Position</div>
      <div>Team</div>
    </div>

    <div id="scoutingReports" class="reports-list">
      <% @scouting_reports.each do |scouting_report| %>
        <%= render "report_tile", scouting_report: scouting_report %>
      <% end %>
    </div>

    <p class="reports-empty" data-report-search-target="empty" hidden>No matching reports.</p>
  </aside>

  <main class="main-panel">
    <%= turbo_frame_tag "main_panel" do %>
      <%= render "dashboard", total_reports: @total_reports, recently_edited_report: @recently_edited_report %>
    <% end %>
  </main>

</div>
