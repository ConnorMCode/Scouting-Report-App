<%= turbo_stream.prepend "scoutingReports", partial: "report_tile", locals: { scouting_report: @scouting_report } %>

<%= turbo_stream.update "flash" do %>
  <%= render "shared/flash", messages: { notice: "Scouting report was successfully created." } %>
<% end %>

<%= turbo_stream.update "main_panel" do %>
  <%= render "report_details", scouting_report: @scouting_report %>
<% end %>
