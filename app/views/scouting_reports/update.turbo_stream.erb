<%= turbo_stream.replace dom_id(@scouting_report, :tile), partial: "report_tile", locals: { scouting_report: @scouting_report } %>

<%= turbo_stream.update "flash" do %>
  <%= render "shared/flash", messages: { notice: "Scouting report was successfully updated." } %>
<% end %>

<%= turbo_stream.update "main_panel" do %>
  <%= render "report_details", scouting_report: @scouting_report %>
<% end %>
